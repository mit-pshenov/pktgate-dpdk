# tests/functional/test_f2_l2.py
#
# M4 C8 — F2.1-F2.9: Happy-path L2 matching, end-to-end.
#
# Injection path: net_tap vdevs (librte_net_tap is available on the dev VM;
# net_pcap PMD was not compiled in). The DPDK binary creates dtap0/dtap1
# kernel tap interfaces; the test harness writes Ethernet frames via
# scapy.sendp() to dtap0 (ingress), then SIGTERMs the binary and inspects
# the "stats_on_exit" JSON log line for per-rule counters.
#
# Observable contract:
#   - stats_on_exit log line carries {rule_id, matched_packets, drops} per rule.
#   - Per-rule counters are bumped by the worker AFTER classify_l2 returns.
#   - D41: every test exercises the top-level classify_l2 entry point.
#
# Covers: F2.1-F2.9, D15 compound, D13 l3_offset, D32 QinQ (F2.3-F2.6), D41.
#
# Prerequisites (GREEN impl in same C8 commit):
#   - worker.cpp: initialize dyn->verdict_action_idx = 0xFFFF before classify_l2,
#     bump counter after match.
#   - main.cpp: emit stats_on_exit log line aggregating ruleset counters at
#     shutdown.

import json
import os
import signal
import subprocess
import tempfile
import time

import pytest
from scapy.all import Ether, Dot1Q, IP, UDP, wrpcap, conf

conf.verb = 0  # suppress scapy output

# Request the session-scoped NM unmanaged fixture for every test in this
# module. This ensures NetworkManager does not manage dtap_f2_rx / dtap_f2_tx
# for the entire pytest session, preventing DHCP background traffic from
# polluting per-rule counter assertions. The fixture is defined in conftest.py.
pytestmark = pytest.mark.usefixtures("nm_unmanaged_tap")

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

DPDK_DRIVER_DIR = os.environ.get(
    "DPDK_DRIVER_DIR", "/home/mit/Dev/dpdk-25.11/build/drivers/"
)

# Port names created by net_tap PMD. The iface= param lets us choose names
# that are unlikely to collide with other tests. Use a unique prefix per test
# module to avoid inter-test collisions when tests run in the same pytest session.
_INGRESS_IFACE = "dtap_f2_rx"
_EGRESS_IFACE  = "dtap_f2_tx"

# EAL args common to all F2 tests. Each test uses a unique --file-prefix to
# avoid EAL shared-memory collisions.
_EAL_ARGS_TEMPLATE = [
    "--no-pci",
    "--no-huge",
    "-m", "64",
    "-d", DPDK_DRIVER_DIR,
    "--vdev", f"net_tap0,iface={_INGRESS_IFACE}",
    "--vdev", f"net_tap1,iface={_EGRESS_IFACE}",
    "-l", "0,1",
    "--log-level", "lib.*:error",
]

# ---------------------------------------------------------------------------
# Sizing: tiny but valid (dev defaults). Use explicit non-zero values so the
# validator does not apply unexpected dev-defaults that differ across commits.
# ---------------------------------------------------------------------------

_SIZING = {
    "rules_per_layer_max": 64,
    "mac_entries_max": 64,
    "ipv4_prefixes_max": 64,
    "ipv6_prefixes_max": 64,
    "l4_entries_max": 64,
    "vrf_entries_max": 8,
    "rate_limit_rules_max": 8,
    "ethertype_entries_max": 64,
    "vlan_entries_max": 64,
    "pcp_entries_max": 8,
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _find_binary():
    """Find pktgate_dpdk binary. Mirrors conftest.py find_binary()."""
    env_path = os.environ.get("PKTGATE_BINARY")
    if env_path and os.path.isfile(env_path):
        return env_path
    base = os.path.dirname(
        os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    )
    for preset in ["dev-asan", "dev-debug", "dev-release", "dev-ubsan", "dev-tsan"]:
        path = os.path.join(base, "build", preset, "pktgate_dpdk")
        if os.path.isfile(path) and os.access(path, os.X_OK):
            return path
    pytest.skip("pktgate_dpdk binary not found")


def _tap_iface_up(iface: str, timeout: float = 5.0) -> bool:
    """Poll until `iface` appears in 'ip link show'. Returns True if found."""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        result = subprocess.run(
            ["ip", "link", "show", iface],
            capture_output=True, text=True
        )
        if result.returncode == 0 and iface in result.stdout:
            return True
        time.sleep(0.1)
    return False


def _delete_stale_tap(iface: str) -> None:
    """Delete a stale tap interface if it exists.

    DPDK net_tap creates persistent TUN/TAP interfaces. If a previous test
    run crashed or the binary was killed before port_stop(), the tap device
    stays. On the next run, DPDK re-creates it — but the kernel may preserve
    the multi-queue state from the old instance (e.g., 3 queues from a debug
    run vs 1 queue expected now). When the device has more active queues than
    the new DPDK instance polls, AF_PACKET TX frames are distributed across
    ALL queues, including those nobody reads. This silently drops injected
    packets.

    Deleting the stale interface before the binary starts ensures a fresh
    1-queue device is created, and AF_PACKET injection reaches DPDK's fd.
    """
    result = subprocess.run(
        ["ip", "link", "show", iface],
        capture_output=True, text=True
    )
    if result.returncode == 0 and iface in result.stdout:
        subprocess.run(["ip", "link", "delete", iface],
                       capture_output=True)  # ignore errors


def _parse_stats_on_exit(stdout: str) -> dict:
    """Parse the stats_on_exit JSON log line from binary stdout.

    Returns a dict {rule_id: {"matched_packets": N, "drops": M}} or {} if
    the line is absent (binary did not emit it — GREEN impl not landed yet).
    """
    for line in stdout.splitlines():
        line = line.strip()
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        if obj.get("event") == "stats_on_exit":
            rules = {}
            for entry in obj.get("rules", []):
                rid = entry.get("rule_id")
                if rid is not None:
                    rules[rid] = {
                        "matched_packets": entry.get("matched_packets", 0),
                        "drops":           entry.get("drops", 0),
                    }
            return rules
    return {}


class _F2Harness:
    """Context manager: start pktgate, wait for ready, inject packets,
    stop, parse stats."""

    def __init__(self, config: dict, file_prefix: str):
        self._config = config
        # Append a monotonic nanosecond suffix so that repeated pytest runs
        # never collide with stale /var/run/dpdk/<prefix>/ directories left
        # by a previous run (e.g. after a timeout or kill). DPDK uses the
        # directory name as a file lock; a stale socket in the old dir can
        # block rte_eal_remote_launch indefinitely on the next run with the
        # same prefix.
        self._file_prefix = f"{file_prefix}_{time.monotonic_ns() % 10**9:09d}"
        self._binary = _find_binary()
        self._proc = None
        self._lines: list = []
        self.stdout_text = ""
        self.returncode = None

    def __enter__(self):
        # Delete stale tap interfaces from previous runs. If a DPDK process
        # was killed before port_stop(), the tap device persists with the old
        # multi-queue layout. This causes AF_PACKET inject to miss DPDK's RX
        # fd when the new run opens fewer queues than the stale device has.
        # Also flushes any kernel-buffered frames from the previous test.
        _delete_stale_tap(_INGRESS_IFACE)
        _delete_stale_tap(_EGRESS_IFACE)

        # Write config to temp file.
        self._tmpf = tempfile.NamedTemporaryFile(
            mode="w", suffix=".json", delete=False
        )
        json.dump(self._config, self._tmpf)
        self._tmpf.close()

        eal_args = _EAL_ARGS_TEMPLATE + [
            "--file-prefix", self._file_prefix,
        ]
        cmd = [self._binary] + eal_args + ["--config", self._tmpf.name]

        # Binary (bytes) mode + bufsize=0 on stdout. We read the raw fd with
        # os.read() and do our own newline splitting, bypassing Python's
        # text-mode line buffer entirely. Rationale: with text=True +
        # select.select(fd) + readline(), a race can leave a complete line
        # sitting in Python's internal text buffer while select reports "no
        # data on the fd" (because all kernel-side bytes have been consumed
        # into Python's buffer). The ready-wait loop then never calls
        # readline() again — because select never flags the fd — and the
        # test times out even though the binary already emitted ready:true.
        # Raw os.read() on the fd has no intermediate buffer, so every byte
        # is visible to the select-driven polling loop immediately.
        self._proc = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            bufsize=0,
        )
        self._lines = []
        self._raw_buf = b""

        # Wait for "ready":true. 15s is comfortable for a net_tap boot
        # under dev-asan (the slowest preset); a real hang will never clear
        # so a longer deadline only delays the failure reporting.
        deadline = time.monotonic() + 15.0
        ready = False
        import select
        while time.monotonic() < deadline:
            r, _, _ = select.select([self._proc.stdout.fileno()], [], [], 0.1)
            if r:
                try:
                    chunk = os.read(self._proc.stdout.fileno(), 4096)
                except OSError:
                    chunk = b""
                if chunk:
                    self._raw_buf += chunk
                    while b"\n" in self._raw_buf:
                        line, self._raw_buf = self._raw_buf.split(b"\n", 1)
                        line_str = line.decode(errors="replace")
                        self._lines.append(line_str)
                        if '"ready":true' in line_str or '"ready": true' in line_str:
                            ready = True
                            break
                    if ready:
                        break
                else:
                    # EOF
                    break
            if self._proc.poll() is not None:
                break

        if not ready:
            # Kill the process so it doesn't linger and block the next test
            # (stale DPDK runtime dir / tap device).
            self._proc.kill()
            try:
                remaining_out, _ = self._proc.communicate(timeout=5)
            except subprocess.TimeoutExpired:
                remaining_out = b""
            if isinstance(remaining_out, bytes):
                remaining_out = remaining_out.decode(errors="replace")
            tail_buf = self._raw_buf.decode(errors="replace")
            self.stdout_text = (
                "\n".join(self._lines) + "\n" + tail_buf + "\n" + remaining_out
            )
            raise RuntimeError(
                f"Binary did not reach ready. exit={self._proc.returncode} "
                f"stdout={self.stdout_text!r}"
            )

        # Wait for the tap interfaces to be visible to the kernel.
        if not _tap_iface_up(_INGRESS_IFACE):
            self._proc.terminate()
            raise RuntimeError(
                f"Tap interface {_INGRESS_IFACE!r} did not appear within 5s"
            )

        # Defense-in-depth: suppress kernel-generated background traffic that
        # could slip through between NM unmanaged-devices configuration (set
        # session-wide by nm_unmanaged_tap fixture in conftest.py) and actual
        # interface creation. These are best-effort — errors are ignored.
        #
        # (1) Disable IPv6 — suppresses NDP / router solicitation (0x86DD).
        subprocess.run(
            ["sysctl", "-qw",
             f"net.ipv6.conf.{_INGRESS_IFACE}.disable_ipv6=1"],
            capture_output=True
        )
        # (2) Flush any IPv4 address NM may have assigned in the race window.
        subprocess.run(
            ["ip", "addr", "flush", "dev", _INGRESS_IFACE],
            capture_output=True
        )
        # (3) Disable ARP — stops kernel ARP solicitations (ethertype 0x0806).
        subprocess.run(
            ["ip", "link", "set", _INGRESS_IFACE, "arp", "off"],
            capture_output=True
        )

        # Settle: allow the kernel-generated burst of control frames (IGMP
        # membership reports, IPv4 multicast probes, etc.) to pass through
        # the DPDK RX ring and be processed by the worker BEFORE we inject
        # test packets. Without this, background frames from the interface
        # UP event arrive in the RX ring alongside our test packets and
        # inflate per-rule counters. The worker drains the ring at ~10 MPPS;
        # a 1.0 s settle window is sufficient for the burst to subside.
        time.sleep(1.0)

        return self

    def inject(self, packets, pause: float = 0.3):
        """Send `packets` (list of scapy packets) to the ingress tap."""
        from scapy.all import sendp, conf as scapy_conf
        # Reload scapy's interface cache so it uses the current if_index
        # for dtap_f2_rx. If a previous test run created and then deleted
        # dtap_f2_rx, scapy caches the old if_index. The new binary creates
        # a fresh interface with a different if_index; the stale cache entry
        # causes ENODEV in the setsockopt promisc call inside sendp.
        scapy_conf.ifaces.reload()
        for pkt in packets:
            sendp(pkt, iface=_INGRESS_IFACE, verbose=False)
        time.sleep(pause)  # give worker a moment to process

    def __exit__(self, exc_type, exc_val, exc_tb):
        # Send SIGTERM and collect output.
        if self._proc and self._proc.poll() is None:
            self._proc.send_signal(signal.SIGTERM)
        try:
            remaining_out, _ = self._proc.communicate(timeout=10)
        except subprocess.TimeoutExpired:
            self._proc.kill()
            remaining_out, _ = self._proc.communicate(timeout=5)

        # stdout is binary (bufsize=0, no text=True); decode + splice with
        # whatever raw bytes we had already slurped into self._raw_buf and
        # the per-line list built during __enter__.
        if isinstance(remaining_out, bytes):
            remaining_out = remaining_out.decode(errors="replace")
        tail_buf = self._raw_buf.decode(errors="replace")
        pre = "\n".join(self._lines)
        combined = pre
        if tail_buf:
            combined = (combined + "\n" + tail_buf) if combined else tail_buf
        if remaining_out:
            combined = (combined + "\n" + remaining_out) if combined else remaining_out
        self.stdout_text = combined
        self.returncode = self._proc.returncode

        # Cleanup.
        if os.path.exists(self._tmpf.name):
            os.unlink(self._tmpf.name)

        time.sleep(0.2)  # let EAL release hugepage mappings
        return False  # do not suppress exceptions


def _config_with_rules(l2_rules: list, default_behavior: str = "drop") -> dict:
    return {
        "version": 1,
        "interface_roles": {
            "upstream_port":   {"vdev": "net_tap0"},
            "downstream_port": {"vdev": "net_tap1"},
        },
        "default_behavior": default_behavior,
        "pipeline": {
            "layer_2": l2_rules,
            "layer_3": [],
            "layer_4": [],
        },
        "sizing": _SIZING,
    }


# ---------------------------------------------------------------------------
# F2.1 — L2 src_mac exact match → drop
#
# One rule: match src_mac=aa:bb:cc:dd:ee:ff, action=drop.
# Two packets: one matching, one with different src_mac.
# Assertion: rule_id=1001 matched_packets=1, drops=1.
# ---------------------------------------------------------------------------

def test_f2_1_l2_src_mac_drop(pktgate_process):
    """F2.1: L2 src_mac exact match → drop. Counter bumped once."""
    config = _config_with_rules([
        {
            "id": 1001,
            "src_mac": "aa:bb:cc:dd:ee:ff",
            "action": {"type": "drop"},
        }
    ])

    pkt_match   = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66")
    pkt_nomatch = Ether(src="00:00:00:00:00:01", dst="11:22:33:44:55:66")

    with _F2Harness(config, "pktgate_f2_1") as h:
        h.inject([pkt_match, pkt_nomatch])

    assert h.returncode == 0, (
        f"Expected exit 0, got {h.returncode}. stdout={h.stdout_text!r}"
    )
    assert "stats_on_exit" in h.stdout_text, (
        f"Missing stats_on_exit in output: {h.stdout_text!r}"
    )
    stats = _parse_stats_on_exit(h.stdout_text)
    assert 1001 in stats, (
        f"Rule 1001 missing from stats: {stats!r}"
    )
    assert stats[1001]["matched_packets"] == 1, (
        f"Expected 1 matched packet for rule 1001, got: {stats[1001]!r}"
    )
    assert stats[1001]["drops"] == 1, (
        f"Expected 1 drop for rule 1001, got: {stats[1001]!r}"
    )


# ---------------------------------------------------------------------------
# F2.2 — L2 dst_mac exact match → allow
#
# Rule: match dst_mac=11:22:33:44:55:66, action=allow.
# Single matching packet.
# Assertion: rule_id=1002 matched_packets=1, drops=0.
# ---------------------------------------------------------------------------

def test_f2_2_l2_dst_mac_allow(pktgate_process):
    """F2.2: L2 dst_mac exact match → allow. Counter bumped, no drop."""
    config = _config_with_rules([
        {
            "id": 1002,
            "dst_mac": "11:22:33:44:55:66",
            "action": {"type": "allow"},
        }
    ])

    pkt_match = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66")

    with _F2Harness(config, "pktgate_f2_2") as h:
        h.inject([pkt_match])

    assert h.returncode == 0
    assert "stats_on_exit" in h.stdout_text, (
        f"Missing stats_on_exit: {h.stdout_text!r}"
    )
    stats = _parse_stats_on_exit(h.stdout_text)
    assert 1002 in stats, f"Rule 1002 missing from stats: {stats!r}"
    assert stats[1002]["matched_packets"] == 1, (
        f"Expected 1 matched packet, got: {stats[1002]!r}"
    )
    assert stats[1002]["drops"] == 0, (
        f"Expected 0 drops for allow rule, got: {stats[1002]!r}"
    )


# ---------------------------------------------------------------------------
# F2.3 — L2 vlan_id match
#
# Rule: vlan_id=100, action=drop.
# Three packets: vlan=100 (match), vlan=200 (miss), untagged (miss).
# Assertion: rule 1003 matched_packets=1.
# ---------------------------------------------------------------------------

def test_f2_3_l2_vlan_id_match(pktgate_process):
    """F2.3: vlan_id=100 rule hits vlan=100 packet only."""
    config = _config_with_rules([
        {
            "id": 1003,
            "vlan_id": 100,
            "action": {"type": "drop"},
        }
    ])

    pkt_vlan100  = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66") / \
                   Dot1Q(vlan=100)
    pkt_vlan200  = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66") / \
                   Dot1Q(vlan=200)
    pkt_untagged = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66")

    with _F2Harness(config, "pktgate_f2_3") as h:
        h.inject([pkt_vlan100, pkt_vlan200, pkt_untagged])

    assert h.returncode == 0
    stats = _parse_stats_on_exit(h.stdout_text)
    assert "stats_on_exit" in h.stdout_text, (
        f"Missing stats_on_exit: {h.stdout_text!r}"
    )
    assert 1003 in stats, f"Rule 1003 missing: {stats!r}"
    assert stats[1003]["matched_packets"] == 1, (
        f"Expected 1 match (vlan=100 only), got: {stats[1003]!r}"
    )


# ---------------------------------------------------------------------------
# F2.4 — untagged frame must not match vlan rule
#
# Rule: vlan_id=100, action=drop.
# Packet: untagged Ethernet frame.
# Assertion: rule 1004 counter stays 0 (or rule_id absent from stats = 0 matches).
# ---------------------------------------------------------------------------

def test_f2_4_l2_untagged_misses_vlan_rule(pktgate_process):
    """F2.4: Untagged frame does not trigger vlan_id=100 rule."""
    config = _config_with_rules([
        {
            "id": 1004,
            "vlan_id": 100,
            "action": {"type": "drop"},
        }
    ])

    pkt_untagged = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66")

    with _F2Harness(config, "pktgate_f2_4") as h:
        h.inject([pkt_untagged])

    assert h.returncode == 0
    assert "stats_on_exit" in h.stdout_text, (
        f"Missing stats_on_exit: {h.stdout_text!r}"
    )
    stats = _parse_stats_on_exit(h.stdout_text)
    # Rule 1004 either absent or matched_packets=0.
    matched = stats.get(1004, {}).get("matched_packets", 0)
    assert matched == 0, (
        f"Expected 0 matches for vlan rule on untagged frame, got: {matched!r}"
    )


# ---------------------------------------------------------------------------
# F2.5 — ethertype match (0x0800 = IPv4)
#
# Rule: src_mac=aa:bb:cc:dd:ee:ff AND ethertype=0x0800, action=drop.
# Three packets: IPv4 from test-src (match), IPv6 from test-src (miss),
#                ARP from test-src (miss).
# Assertion: rule 1005 matched_packets=1.
#
# Note on harness isolation: an ethertype-only rule (without src_mac anchor)
# would match kernel-generated background IPv4 traffic (IGMP reports, DHCP
# discovery frames injected by the host network stack during the 0.3s
# window after inject). Using src_mac=aa:bb:cc:dd:ee:ff as the primary key
# with ethertype=0x0800 as a filter constraint prevents false matches from
# kernel traffic (the kernel uses the tap interface's own hardware MAC as
# src_mac, not aa:bb:cc:dd:ee:ff). This still tests the ethertype filter_mask
# path (D15) — the compound selectivity probe hits src_mac as primary and
# checks ethertype as secondary via filter_mask.
# ---------------------------------------------------------------------------

def test_f2_5_l2_ethertype_match(pktgate_process):
    """F2.5: ethertype=0x0800 filter hits IPv4-from-test-src frame only."""
    config = _config_with_rules([
        {
            "id": 1005,
            "src_mac": "aa:bb:cc:dd:ee:ff",
            "ethertype": 0x0800,
            "action": {"type": "drop"},
        }
    ])

    # Match: test src_mac AND ethertype=0x0800.
    # Note: parentheses around the byte literal are required — scapy's /
    # operator and * have equal precedence (both multiplicative); without
    # parens `Ether / b"\x00" * N` parses as `(Ether / b"\x00") * N`,
    # creating a list of N packets instead of one packet with N-byte payload.
    pkt_ipv4 = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66",
                     type=0x0800) / (b"\x00" * 20)
    # Miss: same src_mac but wrong ethertype (0x86DD). Tests ethertype filter.
    pkt_ipv6 = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66",
                     type=0x86DD) / (b"\x00" * 40)
    # Miss: same src_mac but wrong ethertype (0x0806 ARP). Tests ethertype filter.
    pkt_arp  = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66",
                     type=0x0806) / (b"\x00" * 28)

    with _F2Harness(config, "pktgate_f2_5") as h:
        h.inject([pkt_ipv4, pkt_ipv6, pkt_arp])

    assert h.returncode == 0
    assert "stats_on_exit" in h.stdout_text, (
        f"Missing stats_on_exit: {h.stdout_text!r}"
    )
    stats = _parse_stats_on_exit(h.stdout_text)
    assert 1005 in stats, f"Rule 1005 missing: {stats!r}"
    assert stats[1005]["matched_packets"] == 1, (
        f"Expected 1 match (IPv4+test_src only), got: {stats[1005]!r}"
    )


# ---------------------------------------------------------------------------
# F2.6 — PCP match on VLAN-tagged frame
#
# Rule: vlan_id=100 AND pcp=5, action=drop.
# Two packets: vlan=100 pcp=5 (match), vlan=100 pcp=0 (miss).
# Assertion: rule 1006 matched_packets=1.
# ---------------------------------------------------------------------------

def test_f2_6_l2_pcp_match(pktgate_process):
    """F2.6: vlan=100 + pcp=5 compound. pcp=0 frame misses."""
    config = _config_with_rules([
        {
            "id": 1006,
            "vlan_id": 100,
            "pcp": 5,
            "action": {"type": "drop"},
        }
    ])

    # Scapy Dot1Q: prio field = PCP (3 bits)
    pkt_match = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66") / \
                Dot1Q(vlan=100, prio=5)
    pkt_miss  = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66") / \
                Dot1Q(vlan=100, prio=0)

    with _F2Harness(config, "pktgate_f2_6") as h:
        h.inject([pkt_match, pkt_miss])

    assert h.returncode == 0
    assert "stats_on_exit" in h.stdout_text, (
        f"Missing stats_on_exit: {h.stdout_text!r}"
    )
    stats = _parse_stats_on_exit(h.stdout_text)
    assert 1006 in stats, f"Rule 1006 missing: {stats!r}"
    assert stats[1006]["matched_packets"] == 1, (
        f"Expected 1 match (pcp=5 only), got: {stats[1006]!r}"
    )


# ---------------------------------------------------------------------------
# F2.7 — L2 compound: src_mac + vlan + ethertype (filter_mask path, D15)
#
# Rule: src_mac=aa:bb:cc:dd:ee:ff AND vlan_id=100 AND ethertype=0x0800.
# Packets: all-match (1), wrong-vlan (miss), no-vlan (miss), wrong-etype (miss).
# Assertion: rule 1007 matched_packets=1.
# ---------------------------------------------------------------------------

def test_f2_7_l2_compound_src_mac_vlan_ethertype(pktgate_process):
    """F2.7: Compound src_mac + vlan_id + ethertype. filter_mask path (D15)."""
    config = _config_with_rules([
        {
            "id": 1007,
            "src_mac": "aa:bb:cc:dd:ee:ff",
            "vlan_id": 100,
            "ethertype": 0x0800,
            "action": {"type": "drop"},
        }
    ])

    # Parentheses around the byte literal are required to avoid the
    # `(Ether / b"\x00") * N` list-expansion pitfall (scapy / and * share
    # equal multiplicative precedence, evaluated left-to-right).
    pkt_all_match = (
        Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66") /
        Dot1Q(vlan=100, type=0x0800) /
        (b"\x00" * 20)
    )
    pkt_wrong_vlan = (
        Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66") /
        Dot1Q(vlan=200, type=0x0800) /
        (b"\x00" * 20)
    )
    pkt_no_vlan = (
        Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66",
              type=0x0800) /
        (b"\x00" * 20)
    )
    pkt_wrong_etype = (
        Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66") /
        Dot1Q(vlan=100, type=0x86DD) /
        (b"\x00" * 40)
    )

    with _F2Harness(config, "pktgate_f2_7") as h:
        h.inject([pkt_all_match, pkt_wrong_vlan, pkt_no_vlan, pkt_wrong_etype])

    assert h.returncode == 0
    assert "stats_on_exit" in h.stdout_text, (
        f"Missing stats_on_exit: {h.stdout_text!r}"
    )
    stats = _parse_stats_on_exit(h.stdout_text)
    assert 1007 in stats, f"Rule 1007 missing: {stats!r}"
    assert stats[1007]["matched_packets"] == 1, (
        f"Expected 1 match (all-fields match only), got: {stats[1007]!r}"
    )


# ---------------------------------------------------------------------------
# F2.8 — first-match-wins across rules
#
# R1 id=1008 dst_mac=11:22:33:44:55:66 action=allow (first in config)
# R2 id=1009 src_mac=aa:bb:cc:dd:ee:ff action=drop
# Packet matches both criteria.
# Assertion: R1 counter bumped (first-match), R2 counter = 0 (not reached).
#
# The selectivity order in classify_l2 is: src_mac > dst_mac. So for a
# packet that matches both src_mac (R2) and dst_mac (R1), src_mac probe
# fires first. This tests first-match-wins in the probe order, where the
# "first" match is the one with highest probe selectivity — not config order.
#
# F2.8 therefore focuses on the semantics: whichever rule fires first
# terminates classification. We set R1 to match src_mac (higher selectivity)
# and R2 to match dst_mac. Packet matches both; only R1 counter moves.
# ---------------------------------------------------------------------------

def test_f2_8_l2_first_match_wins(pktgate_process):
    """F2.8: first-match-wins. src_mac rule fires before dst_mac rule."""
    config = _config_with_rules([
        # R1: src_mac match → allow (fires first — src_mac is highest selectivity)
        {
            "id": 1008,
            "src_mac": "aa:bb:cc:dd:ee:ff",
            "action": {"type": "allow"},
        },
        # R2: dst_mac match → drop (src_mac probe already hit, R2 never reached)
        {
            "id": 1009,
            "dst_mac": "11:22:33:44:55:66",
            "action": {"type": "drop"},
        },
    ])

    # Packet matches both rules (src matches R1, dst matches R2).
    pkt = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66")

    with _F2Harness(config, "pktgate_f2_8") as h:
        h.inject([pkt])

    assert h.returncode == 0
    assert "stats_on_exit" in h.stdout_text, (
        f"Missing stats_on_exit: {h.stdout_text!r}"
    )
    stats = _parse_stats_on_exit(h.stdout_text)

    # R1 (src_mac) must have fired.
    assert stats.get(1008, {}).get("matched_packets", 0) == 1, (
        f"Expected R1 (id=1008) matched_packets=1; stats={stats!r}"
    )
    # R2 (dst_mac) must NOT have fired.
    assert stats.get(1009, {}).get("matched_packets", 0) == 0, (
        f"Expected R2 (id=1009) matched_packets=0 (first-match-wins); stats={stats!r}"
    )


# ---------------------------------------------------------------------------
# F2.9 — L2 miss → proceed to L3 (no L2 counter bump)
#
# L2 rule: src_mac=cc:dd:ee:ff:00:11, action=drop.
# Packet: src_mac=aa:bb:cc:dd:ee:ff (different — L2 miss).
# Assertion: rule 1010 counter = 0 (L2 miss passes to L3/default).
#   Binary should exit cleanly (default_behavior=allow so packet passes through).
# Covers: F1 layer fallthrough.
# ---------------------------------------------------------------------------

def test_f2_9_l2_miss_proceeds_to_l3(pktgate_process):
    """F2.9: L2 miss → packet falls through; L2 rule counter stays 0."""
    config = _config_with_rules(
        l2_rules=[
            {
                "id": 1010,
                "src_mac": "cc:dd:ee:ff:00:11",  # won't match our packet
                "action": {"type": "drop"},
            }
        ],
        default_behavior="allow",  # L2 miss → default allow
    )

    # Packet whose src_mac does NOT match the rule.
    pkt = Ether(src="aa:bb:cc:dd:ee:ff", dst="11:22:33:44:55:66")

    with _F2Harness(config, "pktgate_f2_9") as h:
        h.inject([pkt])

    assert h.returncode == 0
    assert "stats_on_exit" in h.stdout_text, (
        f"Missing stats_on_exit: {h.stdout_text!r}"
    )
    stats = _parse_stats_on_exit(h.stdout_text)

    matched = stats.get(1010, {}).get("matched_packets", 0)
    assert matched == 0, (
        f"Expected L2 rule 1010 to have 0 matches (packet should miss); "
        f"got matched_packets={matched!r}, stats={stats!r}"
    )
